---
import Layout from '../layouts/Layout.astro';
import ExampleGrid from '../components/ExampleGrid';
---

<Layout title="Stratos">
  <div class="space-y-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Dashboard</h1>
      <p class="mt-1 text-sm text-gray-500">
        Data is fetched client-side via the BFF proxy. Use the environment switcher above to target a different APIM backend.
      </p>
    </div>

    <ExampleGrid client:load />
  </div>
</Layout>
